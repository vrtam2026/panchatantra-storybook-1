    - target: {fileID: 7040142369068303841, guid: 8379ea736b17c8a4fac6f9a70771e93a, type: 3}
      propertyPath: questions.Array.data[0].questionText
      value: 1,Where was the hungry jackal?
      objectReference: {fileID: 0}
    - target: {fileID: 7040142369068303841, guid: 8379ea736b17c8a4fac6f9a70771e93a, type: 3}
      propertyPath: questions.Array.data[1].questionText
      value: 2,What did the jackal hear?
      objectReference: {fileID: 0}
    - target: {fileID: 7040142369068303841, guid: 8379ea736b17c8a4fac6f9a70771e93a, type: 3}
      propertyPath: questions.Array.data[2].questionText
      value: 3,What did the jackal find when he went to investigate?
      objectReference: {fileID: 0}
    - target: {fileID: 7040142369068303841, guid: 8379ea736b17c8a4fac6f9a70771e93a, type: 3}
      propertyPath: questions.Array.data[3].questionText
      value: 4,The jackal tore open the skin of the drum because
      objectReference: {fileID: 0}
    - target: {fileID: 7040142369068303841, guid: 8379ea736b17c8a4fac6f9a70771e93a, type: 3}
      propertyPath: questions.Array.data[4].questionText
      value: 5,Why are we often scared of the unknown?
      objectReference: {fileID: 0}
    - target: {fileID: 7040142369068303841, guid: 8379ea736b17c8a4fac6f9a70771e93a, type: 3}
      propertyPath: questions.Array.data[5].questionText
      value: 6,What is the worst thing to do when dealing with an unknown?
      objectReference: {fileID: 0}
    - target: {fileID: 7040142369068303841, guid: 8379ea736b17c8a4fac6f9a70771e93a, type: 3}
      propertyPath: questions.Array.data[6].questionText
      value: 7,What did Damanaka tell the king?
      objectReference: {fileID: 0}
    - target: {fileID: 7040142369068303841, guid: 8379ea736b17c8a4fac6f9a70771e93a, type: 3}
      propertyPath: questions.Array.data[7].questionText
      value: '8. Why did Pingalaka think that Damanaka could have a grudge against
        him? '
      objectReference: {fileID: 0}
    - target: {fileID: 7040142369068303841, guid: 8379ea736b17c8a4fac6f9a70771e93a, type: 3}
      propertyPath: questions.Array.data[8].questionText
      value: '9. What did Damanaka tell a scared Pingalaka? '
      objectReference: {fileID: 0}
    - target: {fileID: 7040142369068303841, guid: 8379ea736b17c8a4fac6f9a70771e93a, type: 3}
      propertyPath: questions.Array.data[9].questionText
      value: 10,What did the Sanjivika - the bull, tell Damanaka?
      objectReference: {fileID: 0}
