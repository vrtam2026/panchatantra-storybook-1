    option2IsCorrect: 0
    option3IsCorrect: 1
    option4IsCorrect: 0
    questionAudio: {fileID: 8300000, guid: 39d025a52b87c7147bdb79c7ee74fc4e, type: 3}
    questionVideo: {fileID: 32900000, guid: 727e1bbc3ec96594594637f18ddb4a15, type: 3}
    optionStartTime: 7
  - questionText: 7. Who was the King of Mahilaropya?
    option1: Duryodhan
    option2: Shiv Shakthi
    option3: Rajinikanth
    option4: Amara Shakthi
    option1IsCorrect: 0
