    optionStartTime: 6
  - questionText: 3. Who is the author of th Panchatantra?
    option1: Rohit Sharma
    option2: Vishnu Sharma
    option3: Vyasa
    option4: J.K. Rowling
    option1IsCorrect: 0
    option2IsCorrect: 1
    option3IsCorrect: 0
    option4IsCorrect: 0
